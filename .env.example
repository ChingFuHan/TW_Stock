# 複製此檔為 .env 後填入真實值（.env 已被 .gitignore，不會進版控）
#   Copy-Item .env.example .env

# PostgreSQL 連線（DB 模式 --db-name 需要）
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=your_db_user
PGPASSWORD=your_db_password

# 或改用單一 DSN（設定後優先於上面四項）
# DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/tw

# 選用：外部資料源 token（未使用可留空）
EIKON_TOKEN=
